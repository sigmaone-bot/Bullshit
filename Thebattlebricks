local function switch(tab)
	editorFrame.Visible = tab == "editor"
	antisFrame.Visible = tab == "antis"
end

tabEditor.MouseButton1Click:Connect(function() switch("editor") end)
tabAntis.MouseButton1Click:Connect(function() switch("antis") end)

-- FUNCIONES

local function follow(part, target)
	if active[part] then return end
	active[part] = true

	task.spawn(function()
		while part and part.Parent and targetEnabled do
			local root = target:FindFirstChild("HumanoidRootPart") or target
			if root then
				part.CFrame = root.CFrame
			end
			RunService.Heartbeat:Wait()
		end
		active[part] = nil
	end)
end

local function handleTarget(target)
	for _,v in ipairs(projectileFolder:GetDescendants()) do
		if v:IsA("BasePart") and (v.Name == "Teapot" or v.Name == "FireTeapot") then
			follow(v, target)
		end
	end
end

local function applyAnti(v)
	if v:IsA("BasePart") and v.Name == "RainbowBomb" then
		v.Anchored = true
	end
end

-- LISTA (BIEN HECHA)

local list = Instance.new("ScrollingFrame")
list.Size = UDim2.new(0.9,0,0.65,0)
list.Position = UDim2.new(0.05,0,0.05,0)
list.BackgroundColor3 = Color3.fromRGB(35,35,35)
list.ScrollBarThickness = 5
list.Parent = editorFrame
Instance.new("UICorner", list)

local layout = Instance.new("UIListLayout", list)
layout.Padding = UDim.new(0,5)

layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
	list.CanvasSize = UDim2.new(0,0,0,layout.AbsoluteContentSize.Y+10)
end)

local function refresh()
	for _,v in ipairs(list:GetChildren()) do
		if v:IsA("TextButton") then v:Destroy() end
	end

	for _,enemy in ipairs(enemyFolder:GetChildren()) do
		local b = Instance.new("TextButton")
		b.Size = UDim2.new(1,-10,0,35)
		b.Text = enemy.Name
		b.BackgroundColor3 = Color3.fromRGB(45,45,45)
		b.Parent = list
		Instance.new("UICorner", b)

		b.MouseButton1Click:Connect(function()
			if highlights[enemy] then
				highlights[enemy]:Destroy()
				highlights[enemy] = nil
			else
				local h = Instance.new("Highlight")
				h.FillColor = Color3.fromRGB(255,0,0)
				h.Parent = enemy
				highlights[enemy] = h
				handleTarget(enemy)
			end
		end)
	end
end

refresh()
enemyFolder.ChildAdded:Connect(refresh)
enemyFolder.ChildRemoved:Connect(refresh)

