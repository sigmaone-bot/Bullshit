local function switch(tab)
	editorFrame.Visible = tab == "editor"
	antisFrame.Visible = tab == "antis"
end

local function follow(part, target)
	if active[part] then return end
	active[part] = true

	task.spawn(function()
		while part and part.Parent and targetEnabled do
			if target and target.Parent then
				local root = target:FindFirstChild("HumanoidRootPart") or target
				part.CFrame = root.CFrame
			end
			RunService.Heartbeat:Wait()
		end
		active[part] = nil
	end)
end

local function handleTarget(target)
	for _,obj in ipairs(projectileFolder:GetDescendants()) do
		if obj:IsA("BasePart") and (obj.Name == "Teapot" or obj.Name == "FireTeapot") then
			follow(obj, target)
		end
	end
end

projectileFolder.DescendantAdded:Connect(function(obj)
	if targetEnabled then
		if obj:IsA("BasePart") and (obj.Name == "Teapot" or obj.Name == "FireTeapot") then
			for t,_ in pairs(highlights) do
				follow(obj, t)
				break
			end
		end
	end
end)

local function applyAnti(obj)
	if obj:IsA("BasePart") and obj.Name == "RainbowBomb" then
		obj.Anchored = true
	end
end

projectileFolder.DescendantAdded:Connect(function(obj)
	if antiEnabled then
		applyAnti(obj)
	end
end)

local function refreshList(containerList)
	containerList:ClearAllChildren()
	local y = 0

	for _,enemy in ipairs(enemyFolder:GetChildren()) do
		local btn = Instance.new("TextButton")
		btn.Size = UDim2.new(1,-10,0,40)
		btn.Position = UDim2.new(0,5,0,y)
		btn.Text = enemy.Name
		btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
		btn.Parent = containerList
		Instance.new("UICorner", btn)

		btn.MouseButton1Click:Connect(function()
			if highlights[enemy] then
				highlights[enemy]:Destroy()
				highlights[enemy] = nil
			else
				local h = Instance.new("Highlight")
				h.FillColor = Color3.fromRGB(255,0,0)
				h.Parent = enemy
				highlights[enemy] = h
				handleTarget(enemy)
			end
		end)

		y = y + 45
	end
end

