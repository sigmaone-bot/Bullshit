end)

local function createTab(name, pos, callback)
	local b = Instance.new("TextButton")
	b.Size = UDim2.new(0.5,0,1,0)
	b.Position = UDim2.new(pos,0,0,0)
	b.Text = name
	b.BackgroundColor3 = Color3.fromRGB(45,45,45)
	b.Parent = tabs
	Instance.new("UICorner", b)

	b.MouseButton1Click:Connect(callback)
end

createTab("Newell Editor",0,function() switch("editor") end)
createTab("Antis",0.5,function() switch("antis") end)





